<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="dam.code.controller.Controller"
      spacing="10"
      alignment="CENTER">

    <TextField fx:id="nombreField" promptText="Nombre" />
    <TextField fx:id="edadField" promptText="Edad" />

    <Button text="Añadir entrada" onAction="#addEntrada"/>

    <ListView fx:id="listaEntradas"/>

</VBox>
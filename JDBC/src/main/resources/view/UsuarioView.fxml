<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" alignment="CENTER"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="dam.code.controller.UsuarioController">

    <TextField fx:id="txtNombre" promptText="Nombre"/>
    <TextField fx:id="txtEmail" promptText="Email"/>

    <Button text="Guardar" onAction="#guardarUsuario"/>

    <TableView fx:id="tablaUsuarios">
        <columns>
            <TableColumn fx:id="colId" text="ID"/>
            <TableColumn fx:id="colNombre" text="Nombre"/>
            <TableColumn fx:id="colEmail" text="Email"/>
        </columns>
    </TableView>

</VBox>